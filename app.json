{
  "expo": {
    "name": "EduManage",
    "slug": "edumanage",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "edumanage",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": { "supportsTablet": true, "bundleIdentifier": "ai.edumanage.app" },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/images/logo.png", "backgroundColor": "#ffffff" }, "edgeToEdgeEnabled": true, "package": "ai.edumanage.app" },
    "web": { "bundler": "metro", "output": "static", "favicon": "./assets/images/logo.png" },
    "plugins": ["expo-router", ["expo-splash-screen", { "image": "./assets/images/logo.png", "imageWidth": 200, "resizeMode": "contain", "backgroundColor": "#ffffff" }], "expo-web-browser"],
    "experiments": { "typedRoutes": false }
  }
}
