# EduManage — Environment Configuration
# Copy to .env and fill in your credentials.

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# AI Provider (pick one: openai | anthropic | gemini)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Email (pick one: sendgrid | mailgun)
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=no-reply@edumanage.com
EMAIL_FROM_NAME=EduManage
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# SMS (pick one: africa_talking | twilio)
SMS_PROVIDER=africa_talking
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=

# Cron + Monitoring
CRON_API_KEY=
EXPO_PUBLIC_SENTRY_DSN=

# Test environment (for Jest integration tests)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Flutterwave (African payments — Nigeria, Ghana, Kenya, Uganda, Tanzania, South Africa)
FLUTTERWAVE_SECRET_KEY=

# PayPal (international payments)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox
